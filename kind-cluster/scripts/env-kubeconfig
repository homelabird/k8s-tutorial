#!/bin/sh

CLUSTER_NAME=${1:-cluster}
RUNTIME_ENV_FILE=/etc/ckx-cluster-runtime.env

if [ -f "$RUNTIME_ENV_FILE" ]; then
    . "$RUNTIME_ENV_FILE"
fi

KUBE_API_ENDPOINT=${KUBE_API_ENDPOINT:-k8s-api-server}

cluster_exists() {
    k3d cluster list | awk 'NR > 1 { print $1 }' | grep -Fxq "$CLUSTER_NAME"
}

if [ -z "$CLUSTER_NAME" ]; then
    echo "CLUSTER_NAME is not set"
    exit 1
fi

if ! cluster_exists; then
    echo "K3d cluster '$CLUSTER_NAME' is not running."
    exit 1
fi

k3d kubeconfig get "$CLUSTER_NAME" \
    | sed "s|server: https://127\\.0\\.0\\.1:\\([0-9]*\\)|server: https://${KUBE_API_ENDPOINT}:\\1|"
